generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgType {
  zhk
  kooperativ
}

enum Role {
  platform_admin
  coalition_admin
  org_admin
  council_member
  owner
  tenant
}

enum PetitionStatus {
  DRAFT
  DISCUSSION
  AI_REVISION
  SIGNING
  CLOSED
  EXPORTED
}

enum UserStatus {
  PENDING
  ACTIVE
}

enum PendingStatus {
  PENDING
  APPROVED
  REJECTED
}

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  type      OrgType
  createdAt DateTime @default(now())

  buildings    Building[]
  memberships  Membership[]
  petitions    Petition[]
  inviteLinks  InviteLink[]
  orgGroups    OrgGroupMembership[]
  activities   Activity[]
  chatMessages ChatMessage[]
  assemblies   Assembly[]
}

model Building {
  id                String   @id @default(cuid())
  orgId             String?
  address           String
  addressNormalized String?
  createdBy         String?
  createdAt         DateTime @default(now())

  org        Organization? @relation(fields: [orgId], references: [id])
  apartments Apartment[]

  @@unique([addressNormalized])
  @@index([orgId])
}

model Apartment {
  id         String @id @default(cuid())
  buildingId String
  number     String
  floor      Int?
  entrance   Int?
  areaSqm    Float?

  building    Building     @relation(fields: [buildingId], references: [id])
  memberships Membership[]
  inviteLinks InviteLink[]

  @@unique([buildingId, number])
  @@index([buildingId])
}

model User {
  id               String     @id @default(cuid())
  email            String?    @unique
  phone            String?    @unique
  name             String?
  password         String?
  emailVerified    DateTime?
  phoneVerified    DateTime?
  address          String?    @db.Text
  status           UserStatus @default(ACTIVE)
  profileCompleted Boolean    @default(true)
  shectoryUserId   String?    @unique
  createdAt        DateTime   @default(now())

  accounts              Account[]
  sessions              Session[]
  memberships           Membership[]
  comments              PetitionComment[]
  signatures            PetitionSignature[]
  createdPetitions      Petition[]             @relation("PetitionCreator")
  petitionReactions     PetitionReaction[]
  commentReactions      CommentReaction[]
  activityMemberships   ActivityMembership[]
  createdOrgGroups      OrgGroup[]
  chatMessages          ChatMessage[]
  createdAssemblies     Assembly[]             @relation("AssemblyCreator")
  assemblyVotes         AssemblyVote[]
  pendingRegistration   PendingRegistration?
  ownershipDeclarations OwnershipDeclaration[]
  generatedDocuments    GeneratedDocument[]
  propertyOwnerships    PropertyOwnership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  orgId       String
  apartmentId String?
  role        Role      @default(owner)
  isOwner     Boolean   @default(false)
  areaSqm     Float?
  verifiedAt  DateTime?
  verifiedBy  String?

  user                  User                   @relation(fields: [userId], references: [id])
  org                   Organization           @relation(fields: [orgId], references: [id])
  apartment             Apartment?             @relation(fields: [apartmentId], references: [id])
  ownershipDeclarations OwnershipDeclaration[]

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([apartmentId])
}

model Petition {
  id                 String         @id @default(cuid())
  orgId              String
  title              String
  draftText          String         @db.Text
  finalText          String?        @db.Text
  recipient          String?        @db.Text
  status             PetitionStatus @default(DRAFT)
  discussionDeadline DateTime?
  signingDeadline    DateTime?
  createdBy          String
  createdAt          DateTime       @default(now())
  isPublic           Boolean        @default(true)
  updatedAt          DateTime       @updatedAt

  orgGroupId          String?
  activityId          String?
  templateId          String?
  fieldValues         Json?
  appendixTemplateIds Json?
  docYear             Int?
  docSeq              Int?
  aiSummary           String?        @db.Text

  org               Organization         @relation(fields: [orgId], references: [id])
  createdByUser     User                 @relation("PetitionCreator", fields: [createdBy], references: [id])
  materials         PetitionMaterial[]
  comments          PetitionComment[]
  signatures        PetitionSignature[]
  aiRevisions       PetitionAIRevision[]
  reactions         PetitionReaction[]
  orgGroup          OrgGroup?            @relation(fields: [orgGroupId], references: [id], onDelete: SetNull)
  activity          Activity?            @relation(fields: [activityId], references: [id], onDelete: SetNull)
  template          DocumentTemplate?    @relation(fields: [templateId], references: [id])
  appendixDocuments GeneratedDocument[]
  lawyerMessages    PetitionLawyerMessage[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgGroupId])
  @@index([activityId])
}

model DocumentCounter {
  year    Int @id
  lastSeq Int @default(0)
}

model PetitionLawyerMessage {
  id         String   @id @default(cuid())
  petitionId String
  userId     String?
  role       String   // "user" | "assistant"
  content    String   @db.Text
  createdAt  DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([petitionId])
}

model PlatformSetting {
  key   String @id
  value String
}

model PetitionMaterial {
  id         String   @id @default(cuid())
  petitionId String
  url        String
  name       String
  mimeType   String
  createdAt  DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([petitionId])
}

model PetitionComment {
  id          String   @id @default(cuid())
  petitionId  String
  userId      String
  text        String   @db.Text
  attachments Json?
  createdAt   DateTime @default(now())

  petition  Petition          @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])
  reactions CommentReaction[]

  @@index([petitionId])
  @@index([userId])
}

model PetitionAIRevision {
  id            String    @id @default(cuid())
  petitionId    String
  inputDraft    String    @db.Text
  inputComments Json
  aiSuggestion  String    @db.Text
  aiSummary     String?   @db.Text
  finalText     String?   @db.Text
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime  @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([petitionId])
}

model PetitionSignature {
  id           String   @id @default(cuid())
  petitionId   String
  userId       String
  verifiedVia  String
  legalConsent Boolean  @default(false)
  signedAt     DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([petitionId, userId])
}

model InviteLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  orgId       String
  createdBy   String
  apartmentId String?
  expiresAt   DateTime?
  usedBy      String?
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id])
  apartment Apartment?   @relation(fields: [apartmentId], references: [id])

  @@index([orgId])
  @@index([token])
}

model PetitionReaction {
  id         String   @id @default(cuid())
  petitionId String
  userId     String
  emoji      String   @db.VarChar(10)
  createdAt  DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([petitionId, userId, emoji])
  @@index([petitionId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now())

  comment PetitionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

model OrgGroup {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  createdByUser User                 @relation(fields: [createdBy], references: [id])
  orgs          OrgGroupMembership[]
  petitions     Petition[]
}

model OrgGroupMembership {
  orgGroupId     String
  organizationId String

  orgGroup OrgGroup     @relation(fields: [orgGroupId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([orgGroupId, organizationId])
}

model Activity {
  id        String   @id @default(cuid())
  name      String
  orgId     String?
  createdAt DateTime @default(now())

  org         Organization?        @relation(fields: [orgId], references: [id])
  memberships ActivityMembership[]
  petitions   Petition[]
}

model ActivityMembership {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  joinedAt   DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

enum AssemblyType {
  online
  async_collect
}

enum AssemblyStatus {
  DRAFT
  ANNOUNCED
  VOTING
  CLOSED
}

enum VoteChoice {
  FOR
  AGAINST
  ABSTAIN
}

model Assembly {
  id            String         @id @default(cuid())
  orgId         String
  title         String
  description   String?        @db.Text
  type          AssemblyType
  status        AssemblyStatus @default(DRAFT)
  startsAt      DateTime
  endsAt        DateTime
  quorumPercent Float          @default(50)
  createdBy     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  closedAt      DateTime?

  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdByUser User               @relation("AssemblyCreator", fields: [createdBy], references: [id])
  questions     AssemblyQuestion[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
}

model AssemblyQuestion {
  id                  String  @id @default(cuid())
  assemblyId          String
  order               Int
  text                String  @db.Text
  description         String? @db.Text
  requiredMajorityPct Float   @default(50)

  assembly Assembly       @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  votes    AssemblyVote[]

  @@unique([assemblyId, order])
  @@index([assemblyId])
}

model AssemblyVote {
  id         String     @id @default(cuid())
  questionId String
  userId     String
  choice     VoteChoice
  areaSqm    Float
  isOwner    Boolean
  castAt     DateTime   @default(now())

  question AssemblyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@index([questionId])
}

model PendingRegistration {
  id                String        @id @default(cuid())
  userId            String        @unique
  requestedAddress  String
  addressNormalized String?
  apartmentNumber   String?
  areaSqm           Float?
  isOwner           Boolean       @default(true)
  notes             String?       @db.Text
  status            PendingStatus @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  rejectReason      String?
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([addressNormalized])
}

model OwnershipDeclaration {
  id           String   @id @default(cuid())
  userId       String
  membershipId String
  areaSqm      Float?
  sharePercent Float?
  declaredText String   @db.Text
  smsToken     String
  signedAt     DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([membershipId])
}

model DocumentTemplate {
  id           String   @id @default(cuid())
  category     String
  title        String
  description  String?
  scope        String   // "collective" | "individual"
  layoutKey    String   // "official-letter" | "police-statement" | "explanation"
  bodyTemplate String?  @db.Text
  variables    Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  generatedDocuments GeneratedDocument[]
  petitions          Petition[]
}

model PropertyOwnership {
  id                String    @id @default(cuid())
  userId            String
  address           String
  addressNormalized String?
  apartmentNumber   String?
  areaSqm           Float?
  sharePercent      Float?
  orgId             String?
  orgName           String?
  buildingId        String?
  declaredText      String?   @db.Text
  signedAt          DateTime?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GeneratedDocument {
  id          String    @id @default(cuid())
  userId      String
  templateId  String
  petitionId  String?
  title       String
  fieldValues Json
  status      String    @default("draft") // "draft" | "signed"
  signedAt    DateTime?
  verifiedVia String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DocumentTemplate @relation(fields: [templateId], references: [id])
  petition Petition?        @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([petitionId])
}
