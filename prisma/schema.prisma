generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgType {
  zhk
  kooperativ
}

enum Role {
  platform_admin
  coalition_admin
  org_admin
  council_member
  owner
  tenant
}

enum PetitionStatus {
  DRAFT
  DISCUSSION
  AI_REVISION
  SIGNING
  CLOSED
  EXPORTED
}

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  type      OrgType
  createdAt DateTime @default(now())

  buildings   Building[]
  memberships Membership[]
  petitions   Petition[]
  inviteLinks InviteLink[]
}

model Building {
  id      String @id @default(cuid())
  orgId   String
  address String

  org        Organization @relation(fields: [orgId], references: [id])
  apartments Apartment[]

  @@unique([orgId, address])
  @@index([orgId])
}

model Apartment {
  id         String  @id @default(cuid())
  buildingId String
  number     String
  floor      Int?
  entrance   Int?
  areaSqm    Float?

  building    Building     @relation(fields: [buildingId], references: [id])
  memberships Membership[]
  inviteLinks InviteLink[]

  @@unique([buildingId, number])
  @@index([buildingId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  name          String?
  password      String?
  emailVerified DateTime?
  phoneVerified DateTime?
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  memberships      Membership[]
  comments         PetitionComment[]
  signatures       PetitionSignature[]
  createdPetitions Petition[]          @relation("PetitionCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  orgId       String
  apartmentId String?
  role        Role      @default(owner)
  isOwner     Boolean   @default(false)
  areaSqm     Float?
  verifiedAt  DateTime?

  user      User         @relation(fields: [userId], references: [id])
  org       Organization @relation(fields: [orgId], references: [id])
  apartment Apartment?   @relation(fields: [apartmentId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([apartmentId])
}

model Petition {
  id                 String         @id @default(cuid())
  orgId              String
  title              String
  draftText          String         @db.Text
  finalText          String?        @db.Text
  status             PetitionStatus @default(DRAFT)
  discussionDeadline DateTime?
  signingDeadline    DateTime?
  createdBy          String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  org           Organization         @relation(fields: [orgId], references: [id])
  createdByUser User                 @relation("PetitionCreator", fields: [createdBy], references: [id])
  materials     PetitionMaterial[]
  comments      PetitionComment[]
  signatures    PetitionSignature[]
  aiRevisions   PetitionAIRevision[]

  @@index([orgId])
  @@index([orgId, status])
}

model PetitionMaterial {
  id         String   @id @default(cuid())
  petitionId String
  url        String
  name       String
  mimeType   String
  createdAt  DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([petitionId])
}

model PetitionComment {
  id          String   @id @default(cuid())
  petitionId  String
  userId      String
  text        String   @db.Text
  attachments Json?
  createdAt   DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([petitionId])
  @@index([userId])
}

model PetitionAIRevision {
  id            String    @id @default(cuid())
  petitionId    String
  inputDraft    String    @db.Text
  inputComments Json
  aiSuggestion  String    @db.Text
  aiSummary     String?   @db.Text
  finalText     String?   @db.Text
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime  @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([petitionId])
}

model PetitionSignature {
  id           String   @id @default(cuid())
  petitionId   String
  userId       String
  verifiedVia  String
  legalConsent Boolean  @default(false)
  signedAt     DateTime @default(now())

  petition Petition @relation(fields: [petitionId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([petitionId, userId])
}

model InviteLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  orgId       String
  createdBy   String
  apartmentId String?
  expiresAt   DateTime?
  usedBy      String?
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id])
  apartment Apartment?   @relation(fields: [apartmentId], references: [id])

  @@index([orgId])
  @@index([token])
}
