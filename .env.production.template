# Garden Manager production env template
# Copy to .env on hoster and fill in actual values.
# Run `npx tsx scripts/verify-env.ts` to check completeness.

# ============================================================
# REQUIRED (app won't start without these)
# ============================================================

DATABASE_URL="postgresql://garden_manager_app:PASSWORD@localhost:5432/garden_manager"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://garden.shectory.ru"
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL="https://garden.shectory.ru"

SHECTORY_PORTAL_URL="https://shectory.ru"
SHECTORY_AUTH_BRIDGE_SECRET="same-secret-as-portal-env"

# ============================================================
# RECOMMENDED (graceful dev-fallback if missing)
# ============================================================

# DaData — KLADR address autocomplete
# Get key: https://dadata.ru/api/ → register → "API ключи" → копировать "API-ключ"
DADATA_API_KEY=""

# SMSC.ru — SMS for phone verification + ownership declaration signing.
# Auth via API key (Настройки → Доступ → API-ключи в ЛК SMSC).
SMSC_API_TOKEN=""
SMS_SENDER="SMSC.RU"  # переключить на GARDEN после одобрения имени операторами

# UniSender Go — transactional email (RU-compliant).
# Get key: https://go2.unisender.ru → Настройки → API-ключи.
EMAIL_FROM="noreply@shectory.ru"
EMAIL_FROM_NAME="Garden Manager"
UNISENDER_API_TOKEN=""

# Telegram — admin notifications
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""

PLATFORM_ADMIN_EMAIL=""

# ============================================================
# OPTIONAL
# ============================================================

DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_API_KEY=""

S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

