# Garden Manager production env template (NON-SECRETS ONLY).
#
# СЕКРЕТЫ ИЗ ЭТОГО ФАЙЛА ВЫРЕЗАНЫ — они подтягиваются из Ключника при старте Next.js
# через src/instrumentation.ts. См. SECRETS_PLAYBOOK.md на smain.
#
# Список секретов, которые app ожидает увидеть в process.env после bootstrap:
#   DATABASE_URL                   ← keymaster: GARDEN_DATABASE_URL
#   NEXTAUTH_SECRET                ← keymaster: GARDEN_NEXTAUTH_SECRET
#   SHECTORY_AUTH_BRIDGE_SECRET    ← keymaster: SHECTORY_AUTH_BRIDGE_SECRET
#   DEEPSEEK_API_KEY               ← keymaster: DEEPSEEK_API_KEY
#   SMS_GATEWAY_URL                ← keymaster: GARDEN_SMS_GATEWAY_URL
#   SMS_GATEWAY_AUTH               ← keymaster: GARDEN_SMS_GATEWAY_AUTH
#   SMTP_PASSWORD                  ← keymaster: GARDEN_SMTP_NOREPLY_PASSWORD
#
# Чтобы добавить новый секрет — мап в src/instrumentation.ts + положить в Ключник через TG +
# pre_approve garden-manager@hoster.

# ============================================================
# Public URLs / non-secret config
# ============================================================

NEXTAUTH_URL="https://garden.shectory.ru"
NEXT_PUBLIC_APP_URL="https://garden.shectory.ru"
AUTH_TRUST_HOST=true
SHECTORY_PORTAL_URL="https://shectory.ru"

# SMS sender display name (Боря согласовал у операторов 2026-05-29)
SMS_SENDER="Garden"

# Email / SMTP (non-secret config — пароль в Ключнике как GARDEN_SMTP_NOREPLY_PASSWORD)
EMAIL_FROM="noreply@shectory.ru"
EMAIL_FROM_NAME="Garden Manager"
SMTP_HOST=mail.shectory.ru
SMTP_PORT=587
SMTP_USER=noreply@shectory.ru

# LLM endpoint
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Telegram admin chat for notifications (non-secret — это chat_id, не токен)
TELEGRAM_ADMIN_CHAT_ID=""

# Платформенный админ-email для дублирования критичных уведомлений
PLATFORM_ADMIN_EMAIL=""

# Keymaster — на hoster указываем явно (поскольку hostname() != 'sdev')
KEYMASTER_URL=http://10.66.0.1:9093
KEYMASTER_REQUESTER=garden-manager@hoster
