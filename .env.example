# Garden Manager — example env (non-secrets only).
#
# ВСЕ СЕКРЕТЫ ПОДГРУЖАЮТСЯ ИЗ КЛЮЧНИКА (smain:9093) при старте Next.js
# через src/instrumentation.ts. См. src/lib/keymaster.ts и
# `ssh smain 'cat /home/shectory/workspaces/infra/lineman/docs/AGENT_KEYMASTER_ONBOARDING.md'`.
#
# В этом файле — только PUBLIC URLs и не-секретный конфиг.

# Public URLs
NEXTAUTH_URL="https://garden.shectory.ru"
NEXT_PUBLIC_APP_URL="https://garden.shectory.ru"
AUTH_TRUST_HOST="true"
SHECTORY_PORTAL_URL="https://shectory.ru"

# Non-secret SMS sender display name (одобрено всеми операторами 2026-05-29)
SMS_SENDER="Garden"

# Non-secret email metadata
EMAIL_FROM="noreply@shectory.ru"
EMAIL_FROM_NAME="Garden Manager"

# Non-secret LLM endpoint
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Optional Keymaster overrides
# KEYMASTER_URL=http://10.66.0.1:9093
# KEYMASTER_REQUESTER=garden-manager@hoster
